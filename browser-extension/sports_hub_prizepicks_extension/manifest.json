{
  "manifest_version": 3,
  "name": "Sports Hub PrizePicks Exporter",
  "version": "1.1.0",
  "description": "Captures the selected PrizePicks league and exports all captured projections to CSV for Sports Hub.",
  "permissions": [
    "storage",
    "downloads",
    "activeTab"
  ],
  "host_permissions": [
    "https://app.prizepicks.com/*",
    "https://api.prizepicks.com/*",
    "https://www.prizepicks.com/*"
  ],
  "action": {
    "default_title": "Sports Hub Exporter",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.prizepicks.com/*",
        "https://www.prizepicks.com/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://app.prizepicks.com/*",
        "https://www.prizepicks.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
